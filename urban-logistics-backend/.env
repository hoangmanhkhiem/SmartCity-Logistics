# Environment
NODE_ENV=development
# 3001 để Next.js dev chạy ở 3000; frontend proxy /api/v1 → đây (next.config BACKEND_PROXY_TARGET)
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/urban_logistics?schema=public

# JWT
JWT_SECRET=logistic
JWT_EXPIRATION=7d

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urban_logistics
