  nguonDuLieuDuKien   String? @map("Nguồn dữ liệu dự kiến") @db.Text
  nguonCuThe          String? @map("Nguồn cụ thể (điền sau)") @db.Text
  hangBai             String? @map("Hàng Bài") @db.Text
  phanChuTrinh        String? @map("Phan Chu Trinh") @db.Text
